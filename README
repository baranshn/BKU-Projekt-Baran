<div class="hero">
  <div class="hero-tag">School Engineering Project</div>
  <h1>Playground Master<br>Arduino Smart Car</h1>
  <p>A programmable Arduino-based vehicle with manual joystick control, autonomous obstacle avoidance, servo steering, and a live OLED status display.</p>
  <div class="badge-row">
    <span class="badge accent">Arduino / C++</span>
    <span class="badge">HC-SR04 Ultrasonic</span>
    <span class="badge">Servo Steering</span>
    <span class="badge">OLED Display</span>
    <span class="badge">L298N Motor Driver</span>
    <span class="badge">Status: In Development</span>
  </div>
</div>

<div class="content">

  <section id="description">
    <h2>Project Description</h2>
    <p style="color:var(--text-muted); margin-bottom: 1.5rem;">
      The goal of this project is to design and program a functional smart car using an Arduino microcontroller and C++.
      The vehicle operates in two modes, switchable at runtime via the joystick button.
    </p>
    <div class="mode-grid">
      <div class="mode-card">
        <div class="label">Manual Mode</div>
        <p>Controlled via analog joystick. X-axis handles steering, Y-axis controls throttle and direction.</p>
      </div>
      <div class="mode-card">
        <div class="label">Autonomous Mode</div>
        <p>Ultrasonic sensors measure distances in real time. The car steers automatically to avoid obstacles.</p>
      </div>
    </div>
  </section>

  <section id="hardware">
    <h2>Hardware</h2>

    <h3>Components</h3>
    <table>
      <thead>
        <tr>
          <th>Component</th>
          <th>Model</th>
          <th>Purpose</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Microcontroller</td><td class="mono">Arduino Uno / Mega</td><td>Main processing unit</td></tr>
        <tr><td>Ultrasonic Sensor</td><td class="mono">HC-SR04</td><td>Obstacle distance measurement</td></tr>
        <tr><td>Servo Motor</td><td class="mono">SG90 / MG90S</td><td>Front axle steering</td></tr>
        <tr><td>DC Motor</td><td class="mono">TT Motor</td><td>Rear wheel drive</td></tr>
        <tr><td>Motor Driver</td><td class="mono">L298N</td><td>Speed and direction control</td></tr>
        <tr><td>Joystick</td><td class="mono">KY-023</td><td>Manual input</td></tr>
        <tr><td>OLED Display</td><td class="mono">0.96" SSD1306 I2C</td><td>Live status output</td></tr>
        <tr><td>Power Supply</td><td class="mono">9V Battery / LiPo</td><td>Vehicle power source</td></tr>
        <tr><td>Chassis</td><td class="mono">2WD Smart Car Kit</td><td>Physical frame</td></tr>
      </tbody>
    </table>

    <h3>Pin Mapping</h3>
    <table>
      <thead>
        <tr><th>Arduino Pin</th><th>Component</th></tr>
      </thead>
      <tbody>
        <tr><td class="mono">D3</td><td>Servo (PWM)</td></tr>
        <tr><td class="mono">D5</td><td>Motor Enable (PWM)</td></tr>
        <tr><td class="mono">D6</td><td>Motor IN1</td></tr>
        <tr><td class="mono">D7</td><td>Motor IN2</td></tr>
        <tr><td class="mono">D9</td><td>Ultrasonic TRIG</td></tr>
        <tr><td class="mono">D10</td><td>Ultrasonic ECHO</td></tr>
        <tr><td class="mono">A0</td><td>Joystick X-Axis</td></tr>
        <tr><td class="mono">A1</td><td>Joystick Y-Axis</td></tr>
        <tr><td class="mono">A2</td><td>Joystick Button</td></tr>
        <tr><td class="mono">SDA (A4)</td><td>OLED Display</td></tr>
        <tr><td class="mono">SCL (A5)</td><td>OLED Display</td></tr>
      </tbody>
    </table>
  </section>

  <section id="software">
    <h2>Software</h2>

    <h3>Libraries</h3>
    <pre><code><span class="kw">#include</span> <span class="st">&lt;Servo.h&gt;</span>            <span class="cm">// Servo motor control</span>
<span class="kw">#include</span> <span class="st">&lt;Wire.h&gt;</span>             <span class="cm">// I2C communication</span>
<span class="kw">#include</span> <span class="st">&lt;Adafruit_GFX.h&gt;</span>     <span class="cm">// OLED graphics</span>
<span class="kw">#include</span> <span class="st">&lt;Adafruit_SSD1306.h&gt;</span> <span class="cm">// OLED SSD1306 driver</span></code></pre>

    <h3>Core Logic</h3>
    <pre><code><span class="kw">void</span> <span class="fn">loop</span>() {
  <span class="kw">if</span> (joystick.<span class="fn">buttonPressed</span>()) <span class="fn">toggleMode</span>();

  <span class="kw">if</span> (mode == MANUAL) {
    speed    = joystick.<span class="fn">getY</span>();
    steering = joystick.<span class="fn">getX</span>();
  }

  <span class="kw">if</span> (mode == AUTONOMOUS) {
    distance = ultrasonic.<span class="fn">measure</span>();
    <span class="kw">if</span> (distance &lt; THRESHOLD) <span class="fn">avoid</span>();
    <span class="kw">else</span> <span class="fn">drive</span>(FORWARD);
  }

  servo.<span class="fn">setAngle</span>(steering);
  motor.<span class="fn">setSpeed</span>(speed);
  display.<span class="fn">update</span>(mode, speed, distance);
}</code></pre>

    <h3>Project Structure</h3>
    <div class="tree">
      <span class="dir">playground-master/</span><br>
      ├── <span class="dir">src/</span><br>
      │&nbsp;&nbsp; ├── <span class="file">main.cpp</span><br>
      │&nbsp;&nbsp; ├── <span class="file">motor.cpp / motor.h</span><br>
      │&nbsp;&nbsp; ├── <span class="file">servo_control.cpp / servo_control.h</span><br>
      │&nbsp;&nbsp; ├── <span class="file">ultrasonic.cpp / ultrasonic.h</span><br>
      │&nbsp;&nbsp; ├── <span class="file">joystick.cpp / joystick.h</span><br>
      │&nbsp;&nbsp; └── <span class="file">display.cpp / display.h</span><br>
      ├── <span class="dir">docs/</span><br>
      │&nbsp;&nbsp; ├── <span class="file">wiring_diagram.png</span><br>
