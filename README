      └── <span class="file">README.md</span>
    </div>
  </section>

  <section id="roadmap">
    <h2>Development Plan</h2>
    <div class="phases">
      <div class="phase">
        <div class="phase-num">Phase 01</div>
        <div>
          <div class="phase-title">Planning & Assembly</div>
          <ul class="checklist">
            <li>Finalize component list</li>
            <li>Create wiring schematic</li>
            <li>Assemble chassis and mount components</li>
            <li>Verify power supply and connections</li>
          </ul>
        </div>
      </div>
      <div class="phase">
        <div class="phase-num">Phase 02</div>
        <div>
          <div class="phase-title">Basic Drive System</div>
          <ul class="checklist">
            <li>DC motor control: forward, backward, stop</li>
            <li>Servo steering: left, right, center</li>
            <li>Joystick analog input reading</li>
            <li>Manual drive test</li>
          </ul>
        </div>
      </div>
      <div class="phase">
        <div class="phase-num">Phase 03</div>
        <div>
          <div class="phase-title">Sensor Integration</div>
          <ul class="checklist">
            <li>Initialize HC-SR04 ultrasonic sensor</li>
            <li>Implement real-time distance measurement</li>
            <li>Set collision detection threshold (&lt; 20 cm)</li>
          </ul>
        </div>
      </div>
      <div class="phase">
        <div class="phase-num">Phase 04</div>
        <div>
          <div class="phase-title">Autonomous Mode</div>
          <ul class="checklist">
            <li>Left/right scan via servo to find clear path</li>
            <li>Build obstacle avoidance logic</li>
            <li>Mode toggle via joystick button</li>
            <li>Test with multiple obstacles</li>
          </ul>
        </div>
      </div>
      <div class="phase">
        <div class="phase-num">Phase 05</div>
        <div>
          <div class="phase-title">OLED Display</div>
          <ul class="checklist">
            <li>Initialize display over I2C</li>
            <li>Render current mode (MANUAL / AUTONOMOUS)</li>
            <li>Show live speed and distance values</li>
          </ul>
        </div>
      </div>
      <div class="phase">
        <div class="phase-num">Phase 06</div>
        <div>
          <div class="phase-title">Integration & Submission</div>
          <ul class="checklist">
            <li>Full system integration test</li>
            <li>Code cleanup and documentation</li>
            <li>Prepare final presentation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

